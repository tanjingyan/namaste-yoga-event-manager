<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= settings.siteTitle %> - Admin Home</title>
  <link rel="stylesheet" href="/css/style9.css" />
</head>
<body>

<div class="site-title-wrapper">
  <h1 class="site-title"><%= settings.siteTitle || 'Namaste Yoga' %></h1>
  <p class="site-description"><%= settings.siteDescription || 'Where you can find balance, strength, and peace through mindful yoga practice.' %></p>
</div>

<div class="container">
  <header>
    <h1>Organiser Dashboard</h1>
    <nav style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
      <div>
        <!-- Navigation moved to dropdown -->
      </div>
      <div style="display: flex; align-items: center; gap: 15px;">
        <div class="user-dropdown" style="position: relative;">
          <div class="user-icon" onclick="toggleUserDropdown()" style="cursor: pointer; display: flex; align-items: center; gap: 8px; padding: 8px; border-radius: 6px; background: #f0f0f0; border: 1px solid #ddd;">
            <span style="font-size: 18px;">👤</span>
            <span><strong><%= settings.adminName %></strong></span>
            <span style="font-size: 12px;">▼</span>
          </div>
          <div id="userDropdownMenu" class="dropdown-menu" style="display: none; position: absolute; top: 100%; right: 0; background: white; border: 1px solid #ddd; border-radius: 6px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); min-width: 200px; z-index: 1000;">
            <a href="/admin/settings" style="display: block; padding: 12px 16px; text-decoration: none; color: #333; border-bottom: 1px solid #eee;">⚙️ Settings</a>
            <a href="/admin/create" style="display: block; padding: 12px 16px; text-decoration: none; color: #333; border-bottom: 1px solid #eee;">➕ Create New Event</a>
            <a href="/admin/bookings" style="display: block; padding: 12px 16px; text-decoration: none; color: #333;">📋 View All Bookings</a>
          </div>
        </div>
        <form action="/admin/logout" method="POST" style="display:inline;">
          <button type="submit">Logout</button>
        </form>
      </div>
    </nav>
  </header>

  <!-- Dashboard Statistics -->
  <section class="dashboard-stats" style="margin: 20px 0;">
    <h2 style="color: black;">Dashboard Overview</h2>
    <div class="stats-container" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 30px;">
      <div class="stat-card" style="background: white; color: black; padding: 20px; border-radius: 10px; text-align: center; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border: 1px solid #ddd;">
        <div style="font-size: 2.5em; margin-bottom: 10px;">📊</div>
        <h3 style="margin: 0; font-size: 2em; font-weight: bold;"><%= events.length %></h3>
        <p style="margin: 5px 0 0 0; opacity: 0.7;">Total Events</p>
        <small style="opacity: 0.6;">Published: <%= events.filter(e => e.status === 'Published').length %> | Draft: <%= events.filter(e => e.status === 'Draft').length %></small>
      </div>
      
      <div class="stat-card" style="background: white; color: black; padding: 20px; border-radius: 10px; text-align: center; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border: 1px solid #ddd;">
        <div style="font-size: 2.5em; margin-bottom: 10px;">💰</div>
        <h3 style="margin: 0; font-size: 2em; font-weight: bold;">$<%= tickets.reduce((sum, t) => sum + (t.price * t.quantity_sold), 0).toFixed(2) %></h3>
        <p style="margin: 5px 0 0 0; opacity: 0.7;">Total Revenue</p>
        <small style="opacity: 0.6;">From all bookings</small>
      </div>
    </div>
  </section>

  <!-- Published Sessions -->
  <section>
    <h2 style="color: black;">Published Yoga Sessions</h2>
    <% let publishedEvents = events.filter(e => e.status === 'Published'); %>
    <% if (publishedEvents.length === 0) { %>
      <p>No published events found.</p>
    <% } else { %>
      <div class="card-container">
        <% publishedEvents.forEach(event => {
          const eventTickets = tickets.filter(t => t.event_id === event.event_id);
        %>
          <div class="event-card" onclick="toggleActions(this)">
            <h3><%= event.title %></h3>
            <div class="event-info">
              <div class="event-meta">
                <p><strong>🗓️ Start:</strong> <%= formatDate(event.start_date) %></p>
                <p><strong>🏁 End:</strong> <%= formatDate(event.end_date) %></p>
              </div>
              <div class="price-section">
                <% if (eventTickets.length === 0) { %>
                  <p>No tickets available.</p>
                <% } else { %>
                  <% eventTickets.forEach(t => { %>
                    <p><strong><%= t.type %>:</strong> <%= t.price %> USD (Sold: <%= t.quantity_sold %> / <%= t.quantity %>)</p>
                  <% }) %>
                <% } %>
                <small>incl. Sales tax</small>
              </div>
            </div>

            <hr style="border-color: black;" />

            <p class="event-description"><%= event.description %></p>
            <p><small>Created: <%= formatDate(event.created_at) %></small></p>
            <p><small>Published: <%= formatDate(event.published_at) %></small></p>

            <div class="card-actions">
              <form action="/admin/delete-event/<%= event.event_id %>" method="POST">
                <button type="submit" onclick="return confirm('Delete event <%= event.title %>?')">Delete Event</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

  <!-- Draft Sessions -->
  <section>
    <h2 style="color: black;">Draft Yoga Sessions</h2>
    <% let draftEvents = events.filter(e => e.status === 'Draft'); %>
    <% if (draftEvents.length === 0) { %>
      <p>No draft events found.</p>
    <% } else { %>
      <div class="card-container">
        <% draftEvents.forEach(event => {
          const eventTickets = tickets.filter(t => t.event_id === event.event_id);
        %>
          <div class="event-card" onclick="toggleActions(this)">
            <h3><%= event.title %></h3>
            <div class="event-info">
              <div class="event-meta">
                <p><strong>🗓️ Start:</strong> <%= formatDate(event.start_date) %></p>
                <p><strong>🏁 End:</strong> <%= formatDate(event.end_date) %></p>
              </div>
              <div class="price-section">
                <% if (eventTickets.length === 0) { %>
                  <p>No tickets available.</p>
                <% } else { %>
                  <% eventTickets.forEach(t => { %>
                    <p><strong><%= t.type %>:</strong> <%= t.price %> USD (Sold: <%= t.quantity_sold %> / <%= t.quantity %>)</p>
                  <% }) %>
                <% } %>
                <small>incl. Sales tax</small>
              </div>
            </div>

            <hr style="border-color: black;" />

            <p class="event-description"><%= event.description %></p>
            <p><small>Created: <%= formatDate(event.created_at) %></small></p>
            <p><small>Last Modified: <%= formatDate(event.last_modified_at) %></small></p>

            <div class="card-actions">
              <form action="/admin/publish/<%= event.event_id %>" method="POST" style="display:inline;">
                <button type="submit">Publish</button>
              </form>

              <form action="/admin/edit/<%= event.event_id %>" method="GET" style="display:inline;">
                <button type="submit">Edit</button>
              </form>

              <form action="/admin/delete-event/<%= event.event_id %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this event?');" style="display:inline;">
                <button type="submit">Delete</button>
              </form>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
</div>

<script>
  function toggleActions(card) {
    document.querySelectorAll('.event-card').forEach(el => {
      if (el !== card) el.classList.remove('active');
    });
    card.classList.toggle('active');
  }

  function toggleUserDropdown() {
    const dropdown = document.getElementById('userDropdownMenu');
    dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
  }

  // Close dropdown when clicking outside
  document.addEventListener('click', function(event) {
    const dropdown = document.getElementById('userDropdownMenu');
    const userIcon = document.querySelector('.user-icon');
    
    if (!userIcon.contains(event.target)) {
      dropdown.style.display = 'none';
    }
  });

  // Add hover effects for dropdown items
  document.addEventListener('DOMContentLoaded', function() {
    const dropdownItems = document.querySelectorAll('.dropdown-menu a');
    dropdownItems.forEach(item => {
      item.addEventListener('mouseenter', function() {
        this.style.backgroundColor = '#f5f5f5';
      });
      item.addEventListener('mouseleave', function() {
        this.style.backgroundColor = 'white';
      });
    });
  });
</script>

</body>
</html>