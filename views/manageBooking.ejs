<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Manage Booking</title>
  <link rel="stylesheet" href="/css/style3.css" />
</head>
<body>

  <div class="site-title-wrapper">
  <h1 class="site-title"><%= settings.siteTitle || 'Namaste Yoga' %></h1>
  <p class="site-description"><%= settings.siteDescription || 'Where you can find balance, strength, and peace through mindful yoga practice.' %></p>

  </div>

  <div class="container">
    <div class="back-link-container" style="margin-bottom: 20px;">
      <a href="/" class="back-link">← Back to Main Page</a>
    </div>

    <h1 class="page-title">Manage Your Booking</h1>

    <!-- 🔍 Reservation Lookup Form -->
    <form method="GET" action="/user/managebooking" class="search-form" style="margin-bottom: 30px;">
      <input type="text" name="code" placeholder="Reservation Code (e.g. RSV-A1B2C3)" required style="padding: 8px; width: 250px;" />
      <input type="email" name="email" placeholder="Your Email" required style="padding: 8px; width: 250px;" />
      <button type="submit" style="padding: 8px 12px;">🔍 Search</button>
    </form>

    <!-- ✅ Multiple Ticket Results Display -->
    <% if (searchResults && searchResults.length > 0) { 
         const first = searchResults[0]; %>

      <div class="search-result" style="border: 1px solid #ccc; padding: 15px; background-color: #f9f9f9;">
        <h3>🔎 Reservation Details</h3>
        <p><strong>Name:</strong> <%= first.name %></p>
        <p><strong>Email:</strong> <%= first.email_address %></p>
        <p><strong>Reservation Code:</strong> <%= first.reservation_code %></p>
        <p><strong>Event:</strong> <%= first.title %></p>
        <p><strong>Date:</strong> <%= formatDate(first.start_date) %> to <%= formatDate(first.end_date) %></p>

        <h4>🎫 Tickets Reserved</h4>
        <table style="width:100%; border-collapse: collapse; margin-top: 10px;">
          <thead>
            <tr style="background-color:#eee;">
              <th style="padding: 8px; border: 1px solid #ccc;">Ticket Type</th>
              <th style="padding: 8px; border: 1px solid #ccc;">Quantity</th>
            </tr>
          </thead>
          <tbody>
            <% searchResults.forEach(ticket => { %>
              <tr>
                <td style="padding: 8px; border: 1px solid #ccc;"><%= ticket.ticket_type %></td>
                <td style="padding: 8px; border: 1px solid #ccc;"><%= ticket.quantity %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

    <% } else if (searchTried) { %>
      <p style="color: red;">⚠️ No reservation found for that code and email.</p>
    <% } %>

  </div>

</body>
</html>
